DISCORD_TOKEN=put_your_bot_token_here
DISCORD_CLIENT_ID=put_your_application_id_here

# Optional but recommended while testing. Commands update instantly in this server.
DISCORD_GUILD_ID=put_your_test_server_id_here

# Comma-separated Discord user IDs allowed to use owner voice controls.
# If empty, /voice falls back to users with Move Members permission.
VOICE_CONTROL_USER_IDS=put_your_discord_user_id_here

# Set false if you want to deploy commands manually with npm run deploy:commands.
REGISTER_COMMANDS_ON_START=true

# Turn this on only if the Discord Developer Portal Message Content Intent is also enabled.
# Needed for AI auto-replies in the configured AI channel.
ENABLE_MESSAGE_CONTENT_INTENT=false

BOT_BRAND_NAME=Nexus

GROQ_API_KEY=put_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

OPENROUTER_API_KEY=put_your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://example.com
OPENROUTER_APP_NAME=Browniezzz
AI_PROVIDER=groq
AI_MAX_TOKENS=140
AI_TIMEOUT_MS=15000

# Lavalink music backend. Keep host local when Lavalink runs on the same VPS.
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false
MUSIC_SEARCH_SOURCE=ytsearch
MUSIC_DEFAULT_VOLUME=80

# Storage. Keep json for quick local testing. Use postgres for Supabase.
STORAGE_DRIVER=json
DATABASE_URL=postgresql://postgres:your_database_password@db.yutvxacmxcsnibrxosfw.supabase.co:5432/postgres?sslmode=require
